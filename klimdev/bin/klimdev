#!/usr/bin/env node
import { createRequire } from "module";
import { fileURLToPath } from "url";
import { dirname, join } from "path";

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Try compiled dist first, fall back to tsx for dev
const distEntry = join(__dirname, "../dist/index.js");
const srcEntry = join(__dirname, "../src/index.ts");

import { existsSync } from "fs";

if (existsSync(distEntry)) {
  await import(distEntry);
} else {
  // Development: run via tsx
  const { register } = await import("tsx/esm");
  register();
  await import(srcEntry);
}
